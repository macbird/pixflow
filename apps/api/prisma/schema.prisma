// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  active
  inactive
}

enum UserRole {
  tenant_owner
  tenant_admin
  tenant_operator
  tenant_viewer
}

enum BillingCycle {
  monthly
  quarterly
  yearly
}

enum PlanStatus {
  active
  inactive
}

enum ServerStatus {
  active
  maintenance
  full
  inactive
}

enum CustomerStatus {
  active
  trial
  overdue
  blocked
  inactive
}

enum PaymentProviderType {
  asaas
  efi
  mercadopago
  pushinpay
  infinitypay
}

enum ConnectionRenewalStatus {
  pending
  completed
  cancelled
}

enum WhatsAppProviderType {
  evolution
  meta
}

enum WhatsAppConnectionStatus {
  disconnected
  pending
  connected
}

enum BillingScope {
  platform
  tenant
}

enum BillingInvoiceStatus {
  draft
  open
  paid
  overdue
  canceled
}

enum InvoiceKind {
  subscription
  one_off
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

model Account {
  id         String        @id @default(uuid())
  name       String
  slug       String        @unique
  phone      String?
  status     AccountStatus @default(active)
  planSaas   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  users      AccountUser[]
  plans      Plan[]
  servers    Server[]
  tags       Tag[]
  customers              Customer[]
  subscription           AccountSubscription?
  tenantPaymentConfig    TenantPaymentConfig?
  tenantPaymentCredentials TenantPaymentCredential[]
  tenantPaymentRoutingRules TenantPaymentRoutingRule[]
  tenantWhatsappConfig   TenantWhatsappConfig?
  tenantBillingAutomation TenantBillingAutomationConfig?
  invoices               Invoice[]
  connectionRenewalTasks ConnectionRenewalTask[]
  paymentWebhookLogs   PaymentWebhookLog[]

  @@map("accounts")
}

model AccountUser {
  id           String    @id @default(uuid())
  accountId    String
  account      Account   @relation(fields: [accountId], references: [id])
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(tenant_owner)
  passwordResetRequired Boolean @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("account_users")
}

model Plan {
  id                   String       @id @default(uuid())
  tenantId             String
  account              Account      @relation(fields: [tenantId], references: [id])
  name                 String
  description          String?
  price                Decimal      @db.Decimal(10, 2)
  billingCycle         BillingCycle @default(monthly)
  maxConnections       Int          @default(1)
  extraConnectionPrice Decimal?     @db.Decimal(10, 2)
  status               PlanStatus   @default(active)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  customers            Customer[]

  @@map("plans")
}

model Server {
  id             String       @id @default(uuid())
  tenantId       String
  account        Account      @relation(fields: [tenantId], references: [id])
  name           String
  panelUrl       String
  panelUsername  String?
  panelPasswordEncrypted String?
  panelNotes     String?
  maxConnections Int?
  status         ServerStatus @default(active)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  connections    Connection[]
  tags           Tag[]

  @@map("servers")
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  account   Account  @relation(fields: [tenantId], references: [id])
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customers Customer[]
  servers   Server[]

  @@map("tags")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  account   Account  @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String?
  status    CustomerStatus @default(active)
  
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])
  notes     String?
  expiresAt DateTime?

  connections Connection[]
  tags        Tag[]
  invoices    Invoice[]
  connectionRenewalTasks ConnectionRenewalTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Connection {
  id              String   @id @default(uuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serverId        String
  server          Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  macAddress      String
  applicationName String
  label           String?
  m3u8Link        String?
  connectionRenewalTasks ConnectionRenewalTask[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("connections")
}

model PlatformAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_admins")
}

model PlatformPlan {
  id            String                @id @default(uuid())
  name          String
  priceCents    Int
  billingCycle  BillingCycle          @default(monthly)
  maxCustomers  Int?
  active        Boolean               @default(true)
  isDefault     Boolean               @default(false)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  subscriptions AccountSubscription[]

  @@map("platform_plans")
}

model PlatformPaymentConfig {
  id            String              @id @default("default")
  provider      PaymentProviderType @default(asaas)
  apiKey        String?
  webhookToken  String?
  overdueDays   Int                 @default(7)
  updatedAt     DateTime            @updatedAt

  @@map("platform_payment_config")
}

model PlatformWhatsappConfig {
  id                 String                   @id @default("default")
  provider           WhatsAppProviderType     @default(evolution)
  instanceUrl        String?
  apiKey             String?
  wabaId             String?
  phoneNumberId      String?
  displayPhoneNumber String?
  connectionStatus   WhatsAppConnectionStatus @default(disconnected)
  tokenExpiresAt     DateTime?
  updatedAt          DateTime                 @updatedAt

  @@map("platform_whatsapp_config")
}

model AccountSubscription {
  id             String             @id @default(uuid())
  accountId      String             @unique
  account        Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platformPlanId String
  platformPlan   PlatformPlan       @relation(fields: [platformPlanId], references: [id])
  dueDay         Int                @default(10)
  nextDueDate    DateTime
  status         SubscriptionStatus @default(active)
  startedAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("account_subscriptions")
}

model TenantPaymentCredential {
  id           String              @id @default(uuid())
  accountId    String
  account      Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider     PaymentProviderType
  apiKey       String?
  webhookToken String?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([accountId, provider])
  @@map("tenant_payment_credentials")
}

model TenantPaymentRoutingRule {
  id             String              @id @default(uuid())
  accountId      String
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  minAmountCents Int
  provider       PaymentProviderType
  sortOrder      Int                 @default(0)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([accountId, minAmountCents])
  @@map("tenant_payment_routing_rules")
}

model TenantPaymentConfig {
  id           String              @id @default(uuid())
  accountId    String              @unique
  account      Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider     PaymentProviderType @default(asaas)
  apiKey       String?
  webhookToken String?
  updatedAt    DateTime            @updatedAt

  @@map("tenant_payment_config")
}

model TenantWhatsappConfig {
  id                 String                   @id @default(uuid())
  accountId          String                   @unique
  account            Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider           WhatsAppProviderType     @default(evolution)
  instanceUrl        String?
  apiKey             String?
  wabaId             String?
  phoneNumberId      String?
  displayPhoneNumber String?
  connectionStatus   WhatsAppConnectionStatus @default(disconnected)
  tokenExpiresAt     DateTime?
  updatedAt          DateTime                 @updatedAt

  @@index([phoneNumberId])
  @@map("tenant_whatsapp_config")
}

model TenantBillingAutomationConfig {
  id                    String   @id @default(uuid())
  accountId             String   @unique
  account               Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  daysBeforeDue         Int      @default(3)
  sendWhatsapp          Boolean  @default(true)
  sendPaymentCharge     Boolean  @default(true)
  active                Boolean  @default(true)
  chargeMessageTemplates Json?
  chargeMessageDelayMs  Int      @default(1500)
  oneOffMessageTemplates Json?
  automationRunHour     Int      @default(9)
  automationRunMinute   Int      @default(0)
  autoCloseSubscriptionInvoices Boolean @default(false)
  closeSubscriptionInvoiceAfterDays Int @default(30)
  overdueRemindersEnabled       Boolean  @default(false)
  overdueReminderDays           Int[]    @default([1, 7, 15])
  overdueReminderFailureGraceDays Int    @default(1)
  overdueMessageTemplates       Json?
  updatedAt             DateTime @updatedAt

  @@map("tenant_billing_automation_config")
}

model Invoice {
  id                String               @id @default(uuid())
  scope             BillingScope
  kind              InvoiceKind          @default(subscription)
  accountId         String
  account           Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customerId        String?
  customer          Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  billingCycleKey   String
  description       String?
  amountCents       Int
  dueDate           DateTime
  status            BillingInvoiceStatus @default(open)
  paymentProvider   PaymentProviderType?
  pixCopyPaste      String?
  pixQrCodeBase64   String?
  providerChargeId  String?              @unique
  paidAt            DateTime?
  chargeMessageTemplates Json?
  chargeMessageDelayMs   Int?
  replacesInvoiceId String?              @unique
  replacesInvoice   Invoice?             @relation("InvoiceReplacement", fields: [replacesInvoiceId], references: [id], onDelete: SetNull)
  replacement       Invoice?             @relation("InvoiceReplacement")
  canceledAt        DateTime?
  cancelReason      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  payments                 Payment[]
  connectionRenewalTasks   ConnectionRenewalTask[]
  chargeDeliveries         InvoiceChargeDelivery[]

  @@index([scope, accountId, customerId, billingCycleKey])
  @@index([accountId, scope, status])
  @@index([accountId, kind, status])
  @@map("invoices")
}

model InvoiceChargeDelivery {
  id                 String   @id @default(uuid())
  invoiceId          String
  invoice            Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  channel            String   @default("whatsapp")
  source             String
  sentAt             DateTime @default(now())
  messagesCount      Int
  providerMessageIds Json?
  success            Boolean  @default(true)
  errorMessage       String?
  windowDaysAfterDue Int?

  @@index([invoiceId, sentAt])
  @@index([invoiceId, source, windowDaysAfterDue])
  @@map("invoice_charge_deliveries")
}

model BillingJobRun {
  id         String    @id @default(uuid())
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String
  summary    Json?

  @@index([startedAt])
  @@map("billing_job_runs")
}

model Payment {
  id                     String                  @id @default(uuid())
  invoiceId              String
  invoice                Invoice                 @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountCents            Int
  method                 String
  source                 String                  @default("manual")
  notes                  String?
  providerPaymentId      String?                 @unique
  paidAt                 DateTime                @default(now())
  createdAt              DateTime                @default(now())
  connectionRenewalTasks ConnectionRenewalTask[]

  @@map("payments")
}

model ConnectionRenewalTask {
  id           String                  @id @default(uuid())
  tenantId     String
  account      Account                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  connectionId String?
  connection   Connection?             @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  paymentId    String
  payment      Payment                 @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId    String?
  invoice      Invoice?                @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  status       ConnectionRenewalStatus @default(pending)
  paidAt       DateTime
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([paymentId])
  @@index([tenantId, status, paidAt])
  @@index([customerId, status])
  @@map("connection_renewal_tasks")
}

model PaymentWebhookLog {
  id           String   @id @default(uuid())
  accountId    String?
  account      Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tenantSlug   String
  provider     String   @default("mercadopago")
  httpMethod   String
  paymentId    String?
  statusCode   Int
  outcome      String
  detail       String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([tenantSlug, createdAt])
  @@map("payment_webhook_logs")
}
