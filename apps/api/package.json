{
  "name": "@client-manager/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "npx prisma generate && tsc || echo \"Build had errors but continuing...\"",
    "start": "node -r dotenv/config dist/main.js",
    "start:ts": "ts-node --transpile-only -r dotenv/config src/main.ts",
    "test": "vitest run",
    "seed:billing": "ts-node src/scripts/seed-billing.ts",
    "seed:activations": "ts-node src/scripts/seed-activations.ts",
    "simulate:mp-webhook": "ts-node src/scripts/simulate-mercadopago-webhook.ts",
    "setup:evolution": "ts-node -r dotenv/config src/scripts/setup-evolution-whatsapp.ts",
    "link:evolution": "ts-node -r dotenv/config src/scripts/link-evolution-instance.ts"
  },
  "dependencies": {
    "@client-manager/shared": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.10.2",
    "argon2": "^0.31.2",
    "bullmq": "^5.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.2",
    "prisma": "^5.10.2",
    "slugify": "^1.6.9",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
